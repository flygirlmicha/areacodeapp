{
  "manifest_version": 3,
  "name": "Network Lookup Tools",
  "version": "1.1",
  "description": "Area code, domain WHOIS, and IP geolocation lookups.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://tools.spamuraiwarrior.com/*"
  ]
}
